# ─── NETHEX environment template ─────────────────────────────────────────
# Copy to .env and fill in. Never commit .env. All values have safe fallbacks
# so the stack boots even when secrets are absent (degraded/mock mode).

# ── Core ──
NODE_ENV=development
APP_NAME=NETHEX

# ── API (Fastify) ──
API_PORT=8080
API_HOST=0.0.0.0
# Public origin the browser uses to reach the API + WS terminal
PUBLIC_API_URL=http://localhost:8080
# CORS allowlist (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Auth ──
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d
# Argon2/bcrypt rounds for password hashing
BCRYPT_ROUNDS=12

# ── Postgres ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nethex
POSTGRES_PASSWORD=nethex
POSTGRES_DB=nethex
DATABASE_URL=postgresql://nethex:nethex@localhost:5432/nethex

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Lab broker ──
BROKER_PORT=8090
BROKER_URL=http://localhost:8090
# Default lab session TTL (seconds) and per-user concurrent quota
LAB_TTL_SECONDS=3600
LAB_MAX_PER_USER=2
# Docker network mode for labs: "none" enforces egress isolation (recommended)
LAB_EGRESS=none

# ── AI proxy (Anthropic) ──
# When absent, the AI mentor falls back to a deterministic local stub.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
AI_RATE_LIMIT_PER_MIN=20

# ── Frontend (Vite, must be prefixed VITE_) ──
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_APP_NAME=NETHEX
